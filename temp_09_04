                           debug_jamm_cnt1              <= debug_jamm_cnt1 + '1';
                        else       
                            cnt_jam                     <= cnt_jam;
                        end if;
                        
                        if(lo_en_trig_pul_f   = '1' and cnt_jam >= x"000001") then
                            jamm_eligible_en            <= '1';
                        end if;
                                
