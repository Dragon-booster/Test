--                                local_jam_en_buf <= '0';
--                        end if;
                        
                            if  jamm_eligible_en = '1' then  
                                local_jam_en_buf <= '1';
                            else 
                                local_jam_en_buf <= '0';
                            end if;
                        
                        
                        if(jammer_lookthrough = '1') then
